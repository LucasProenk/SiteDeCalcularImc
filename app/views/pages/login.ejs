<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/css/baseimc.css">
</head>
<body>
<div class="card">
  <h1>Entrar</h1>

  <% if (typeof erro !== 'undefined') { %>
    <p style="color:#6200ff; text-align:center; margin-bottom:1rem;"><%= erro %></p>
  <% } %>

  <form action="/login" method="POST">
    <div class="input-group" style="margin-bottom:1rem;">
      <label>Email</label>
      <input type="text" name="email" placeholder="pedro@email.com">
    </div>
    <div class="input-group" style="margin-bottom:1rem;">
      <label>Senha</label>
      <input type="password" name="senha" placeholder="••••••••">
    </div>
    <button type="submit">Entrar</button>
  </form>

  <p style="text-align:center; margin-top:1rem; color:#94a3b8; font-size:0.85rem;">
    Não tem conta? <a href="/cadastro" style="color:#8c00ff;">Cadastre-se</a>
  </p>
</div>
</body>
</html>